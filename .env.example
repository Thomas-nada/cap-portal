# Copy this to .env and fill in real values before running docker compose up

# ── Required ─────────────────────────────────────────────────────────────────

# PostgreSQL password — use a long random string (openssl rand -hex 32)
POSTGRES_PASSWORD=change-me

# JWT signing secret — use a long random string (openssl rand -hex 32)
JWT_SECRET=change-me

# ── Optional ─────────────────────────────────────────────────────────────────

# Email notifications (leave blank to disable)
# Recommended: Resend (resend.com) — free tier, no credit card required
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USERNAME=resend
SMTP_PASSWORD=your-resend-api-key
SMTP_FROM=noreply@yourdomain.com

# Public URL of the portal (used in email links)
APP_URL=https://your-domain.com

# Backup retention in days (default: 7)
BACKUP_RETAIN_DAYS=7
